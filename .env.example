# Authorize.Net sandbox credentials for running the integration test suite.
#
# Copy this file to `.env.local` (which is gitignored) and fill in the values
# from your sandbox account at https://sandbox.authorize.net.
#
# These names match the env-var fallback in AuthorizeNETtest/UnitTestData.cs
# (Authorize.NET/Util/Constants.cs: EnvApiLoginid / EnvTransactionKey / EnvMd5Hashkey).

API_LOGIN_ID=
TRANSACTION_KEY=

# Optional. Leave blank if you don't have one — the integration tests load it
# but never assert on it, and the bootstrap only requires the two values above.
MD5_HASH_KEY=
